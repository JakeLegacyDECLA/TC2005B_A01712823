<%- include('includes/_header') %>

<div class="box">
  <h2 class="title is-4">Iniciar Sesión</h2>
  
  <% if (error) { %>
    <div class="notification is-danger">
      <button class="delete"></button>
      <%= error %>
    </div>
  <% } %>

  <form action="/users/login" method="POST">
    <div class="field">
      <label for="username" class="label">Nombre de usuario</label>
      <div class="control">
        <input id="username" name="username" class="input" type="text" placeholder="Ingresa tu nombre de usuario" required>
      </div>
    </div>

    <div class="field">
      <label for="password" class="label">Contraseña</label>
      <div class="control">
        <input id="password" name="password" class="input" type="password" placeholder="Ingresa tu contraseña" required>
      </div>
    </div>

    <div class="field is-grouped">
      <div class="control">
        <input class="button is-primary" type="submit" value="Entrar">
      </div>
      <div class="control">
        <a class="button is-light" href="/">Cancelar</a>
      </div>
    </div>
  </form>

  <p class="mt-3">
    ¿No tienes cuenta? <a href="/users/signup">Registrate aquí</a>
  </p>
</div>

<%- include('includes/_footer') %>
