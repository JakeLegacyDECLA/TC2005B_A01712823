<section class="section">
	<div class="container">
		<h1 class="title">Nuevo Personaje</h1>
		<form action="/personajes/add" method="POST" enctype="multipart/form-data">
			<input type="hidden" name="_csrf" value="<%= csrfToken %>">
			<div class="field">
				<label class="label">Nombre</label>
				<div class="control">
					<input class="input" type="text" name="nombre" required>
				</div>
			</div>
			<div class="field">
				<label class="label">Descripción</label>
				<div class="control">
					<input class="input" type="text" name="descripcion" required>
				</div>
			</div>
			<div class="field">
				<label class="label">Tipo</label>
				<div class="control">
					<div class="select">
						<select name="tipo" required>
							<% if (tipos && tipos.length > 0) { %>
								<% tipos.forEach(function(tipo) { %>
									<option value="<%= tipo.id %>"><%= tipo.nombre %></option>
								<% }); %>
							<% } %>
						</select>
					</div>
				</div>
			</div>
			<div class="field">
				<label class="label">Imagen</label>
				<div class="control">
					<input class="input" type="file" name="imagen" accept="image/png,image/jpeg,image/jpg" <% if (!edit) { %>required<% } %>>
					<% if (edit && personaje && personaje.imagen) { %>
						<p class="help">Imagen actual: <%= personaje.imagen %></p>
					<% } %>
				</div>
			</div>
			<div class="field is-grouped">
				<div class="control">
					<button class="button is-link" type="submit"><%= edit ? 'Actualizar' : 'Crear' %></button>
				</div>
				<div class="control">
					<a class="button is-light" href="/personajes">Cancelar</a>
				</div>
			</div>
		</form>
	</div>
</section>
