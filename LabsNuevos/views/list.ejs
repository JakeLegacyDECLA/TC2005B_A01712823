<%- include('includes/_header') %>

<div class="container">
    <div class="box">
        <h2 class="subtitle is-5">ℹ️ Componentes AJAX Utilizados:</h2>
        <ul style="margin-left: 20px;">
            <li>✓ <strong>Cambio de Tipo de Personaje:</strong> Al cambiar el tipo en el selector, se actualiza asincronamente sin recargar la página</li>
        </ul>
    </div>
</div>

<div class="container" style="margin-top: 20px;">
    <% for (let permiso of permisos) { %>
        <% if (permiso.nombre_privilegio == 'can-create') { %>
            <a class="button is-primary" href="/personajes/add">Nuevo personaje</a>
        <% } %>
    <% } %>

    <div class="columns">

    <% if(personajes.length == 0) { %>
        <div class="column">
            No hay personajes registrados.
        </div>
    <% } else { %>

        <% for (let personaje of personajes) { %>

            <div class="column">
                <div class="card">
                    <div class="card-image">
                        <figure class="image is-4by3">
                            <img class="is-rounded" src="<%= personaje.imagen %>" alt="<%= personaje.nombre %>"/>
                        </figure>
                    </div>
                    <div class="card-content">
                        <div class="media">
                            <div class="media-content">
                                <p class="title is-4"><%= personaje.nombre %></p>
                                <p class="subtitle is-6"><%= personaje.descripcion %></p>
                            </div>
                        </div>
                        <div class="content">
                            <label class="label">Tipo (AJAX)</label>
                            <div class="select">
                                <select class="tipo-selector-ajax" data-personaje-id="<%= personaje.id %>" id="tipo_<%= personaje.id %>">
                                    <option value="">Cargando...</option>
                                </select>
                            </div>
                            <p class="help">Los cambios se guardan automáticamente</p>
                        </div>
                    </div>
                    <footer class="card-footer">
                        <a class="card-footer-item button is-primary" href="/personajes/<%= personaje.id %>/edit">
                            <span>Editar Completo</span>
                        </a>
                    </footer>
                </div>
            </div>
                
        <% } %>
        
    <% } %>

    </div>
</div>

<!-- Token CSRF para peticiones AJAX -->
<input type="hidden" id="_csrf" value="<%= csrfToken %>">

<!-- Script AJAX -->
<script src="/js/ajax-personajes.js"></script>

<%- include('includes/_footer') %>